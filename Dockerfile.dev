# syntax=docker/dockerfile:1
# Development image — all gem groups installed, non-root user matches VS Code devcontainer conventions.
FROM ruby:4.0.4-slim-trixie

RUN apt-get update && apt-get install -y --no-install-recommends \
  build-essential \
  ca-certificates \
  libpq-dev \
  tzdata \
  git \
  curl \
  gnupg \
  lsb-release \
  unzip \
  postgresql-client \
  && rm -rf /var/lib/apt/lists/*

# ── OpenTofu ──────────────────────────────────────────────────────────────────
# Install via the official apt repository (replaces terraform)
RUN curl -fsSL https://get.opentofu.org/opentofu.gpg \
  | gpg --dearmor -o /usr/share/keyrings/opentofu.gpg && \
  curl -fsSL https://packages.opentofu.org/opentofu/tofu/gpgkey \
  | gpg --no-tty --batch --dearmor -o /usr/share/keyrings/opentofu-repo.gpg && \
  echo "deb [signed-by=/usr/share/keyrings/opentofu.gpg,/usr/share/keyrings/opentofu-repo.gpg] \
  https://packages.opentofu.org/opentofu/tofu/any/ any main" \
  > /etc/apt/sources.list.d/opentofu.list && \
  apt-get update && apt-get install -y --no-install-recommends tofu && \
  rm -rf /var/lib/apt/lists/*

# ── Azure CLI ─────────────────────────────────────────────────────────────────
RUN curl -sL https://aka.ms/InstallAzureCLIDeb | bash && \
  rm -rf /var/lib/apt/lists/*

# ── Infracost CLI ─────────────────────────────────────────────────────────────
RUN curl -kfsSL -o /tmp/infracost-linux-arm64.tar.gz \
  https://github.com/infracost/infracost/releases/download/v0.10.44/infracost-linux-arm64.tar.gz && \
  tar -xzf /tmp/infracost-linux-arm64.tar.gz -C /tmp && \
  install -m 0755 /tmp/infracost-linux-arm64 /usr/local/bin/infracost && \
  rm -f /tmp/infracost-linux-arm64.tar.gz /tmp/infracost-linux-arm64

# Remove conflicting default gemspecs that cause bundle issues
RUN rm -f /usr/local/lib/ruby/gems/4.0.0/specifications/default/json-2.18.0.gemspec \
  /usr/local/lib/ruby/gems/4.0.0/specifications/net-imap-0.6.2.gemspec

# Create a non-root user matching VS Code's expected UID (1000)
RUN groupadd --gid 1000 vscode && useradd --uid 1000 --gid vscode --shell /bin/bash --create-home vscode

WORKDIR /workspace/blog

# Pre-install gems into the bundle cache volume; actual install happens in postCreateCommand
COPY Gemfile Gemfile.lock ./
RUN bundle install --jobs 4 --retry 3

USER vscode
